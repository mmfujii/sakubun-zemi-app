{
  "name": "@sakubun-zemi/infra",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "infra": "bin/infra.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "synth": "cdk synth",
    "deploy": "cdk deploy",
    "diff": "cdk diff",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf cdk.out dist",
    "aws:up": "bash scripts/aws-up.sh",
    "aws:down": "bash scripts/aws-down.sh"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.173.0",
    "constructs": "^10.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "aws-cdk": "^2.173.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
